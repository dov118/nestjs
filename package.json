{
  "name": "@dov118/nestjs",
  "version": "1.0.0-dev.0",
  "description": "Template for NestJS",
  "author": "@dov118 <contact.dov118.dev@gmail.com> (https://dov118.dev)",
  "license": "MIT",
  "engineStrict": true,
  "engines": {
    "node": "24.16.0"
  },
  "bugs": {
    "url": "https://github.com/dov118/nestjs/issues"
  },
  "homepage": "https://github.com/dov118/nestjs#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:dov118/nestjs.git"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch",
    "test:cov": "jest --runInBand --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json",
    "migration:run": "typeorm migration:run -d ./dist/config/typeorm.config.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/testing": "11.1.27",
    "@nestjs/typeorm": "11.0.2",
    "@nestjs/websockets": "11.1.27",
    "@types/morgan": "1.9.10",
    "dotenv": "17.4.2",
    "moment": "2.30.1",
    "morgan": "1.11.0",
    "mysql2": "3.22.5",
    "reflect-metadata": "0.2.2",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "sqlite3": "5.1.7",
    "supertest": "7.2.2",
    "typeorm": "0.3.30",
    "typeorm-extension": "3.9.0",
    "winston": "3.19.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/schematics": "11.1.0",
    "@types/jest": "30.0.0",
    "@types/supertest": "6.0.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.e2e-spec\\.ts|.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "dotenv/config"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "modulePaths": [
      "<rootDir>"
    ]
  },
  "overrides": {
    "tar": "7.5.16",
    "js-yaml": "4.2.0",
    "sqlite3": {
      "node-gyp": "10.0.0"
    }
  }
}
